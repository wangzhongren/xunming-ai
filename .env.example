# xunming-ai 环境变量配置
# 兼容 OpenAI 格式的 API 端点 (可自由替换为 DeepSeek、Claude 等)

OPENAI_API_KEY=your-api-key-here
# API 基础 URL，默认 OpenAI；使用 DeepSeek 则设为 https://api.deepseek.com/v1
API_BASE_URL=https://api.openai.com/v1
# 默认模型名称，各 Agent 可在构造函数中单独覆盖
MODEL_NAME=gpt-4o
# 工作空间目录，所有工具的文件操作限定在此目录内
WORKSPACE_DIR=~/xunming-workspace
